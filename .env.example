# Copy this file to .env and fill in real values. Never commit .env.

# --- Fabric (source: smc_dwh warehouse) ---
FABRIC_CLIENT_ID=
FABRIC_CLIENT_SECRET=
FABRIC_TENANT_ID=
FABRIC_SQL_ENDPOINT=
FABRIC_DATABASE=

# --- Postgres (portfolio_monitoring, Azure Flexible Server) ---
# Entra ID auth: password field takes a short-lived access token, not a static password.
# Regenerate via:
#   az login --tenant cd42ad31-bf24-4569-91e9-e4e961d2a99c --allow-no-subscriptions
#   az account get-access-token --resource-type oss-rdbms --query accessToken -o tsv
PG_HOST=ml-financials-db.postgres.database.azure.com
PG_PORT=5432
PG_DATABASE=portfolio_monitoring
PG_USER=henry.yan@starmountaincapital.com
PG_PASSWORD=